PORT=8080

# Railway MongoDB template exposes MONGO_URL. MONGODB_URI is also supported.
MONGO_URL=mongodb://localhost:27017/meterflow

# Redis is optional for local demos. Use Railway/Render Redis values in production.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRATION_MS=86400000

# Comma-separated frontend origins. Add your Vercel URL after deployment.
FRONTEND_URL=http://localhost:5173

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PRO_PLAN_ID=
